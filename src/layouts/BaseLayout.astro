---
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Jalal Eddine Maoukil's personal website and portfolio." />
    <link rel="icon" type="image/svg+xml" href="/images/icon.svg" />
    <title>Jalal Eddine Maoukil</title>

    <link rel="preload" as="image" href="/images/profile.webp" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- GSAP (load once globally) -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/SplitText.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/CustomEase.min.js" defer></script>
  </head>

  <body>
    <Preloader />
    <slot />
  </body>
</html>
