<script>
  import Lenis from "lenis";

  const prefersReduced = window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches;
  const isCoarsePointer = window.matchMedia?.("(pointer: coarse)")?.matches;
  const saveData = navigator.connection?.saveData === true;
  const lowMemory = typeof navigator.deviceMemory === "number" && navigator.deviceMemory <= 4;
  const lowCpu = typeof navigator.hardwareConcurrency === "number" && navigator.hardwareConcurrency <= 4;

  const disableLenis = true;
  const shouldUseLenis = !disableLenis && !prefersReduced && !isCoarsePointer && !saveData && !lowMemory && !lowCpu;
  let lenis = null;
  let resizeObserver = null;

  if (shouldUseLenis) {
    const wrapper = window;
    const content = document.body;
    lenis = new Lenis({
      wrapper,
      content,
      lerp: 0.045,
      duration: 1.1,
      smoothWheel: true,
      smoothTouch: false,
      wheelMultiplier: 0.95,
      touchMultiplier: 1.0,
      normalizeWheel: true,
      autoRaf: false,
      autoResize: true,
    });
  }

  const attachRaf = () => {
    if (!lenis) return;
    if (window.gsap?.ticker) {
      window.gsap.ticker.add((t) => {
        lenis.raf(t * 1000);
      });
      window.gsap.ticker.lagSmoothing(0);
      return;
    }

    const raf = (time) => {
      lenis.raf(time);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
  };

  const syncScrollTrigger = () => {
    if (!window.ScrollTrigger) return;
    if (!lenis) {
      window.ScrollTrigger.refresh();
      return;
    }
    lenis.on("scroll", window.ScrollTrigger.update);
    window.ScrollTrigger.refresh();
  };

  attachRaf();
  syncScrollTrigger();

  const refreshAll = () => {
    if (lenis?.resize) lenis.resize();
    if (window.ScrollTrigger?.refresh) window.ScrollTrigger.refresh();
  };

  const unlockIfNavClosed = () => {
    const navOpen = document.querySelector('[data-nav-state="open"]');
    if (!navOpen) document.documentElement.style.overflow = "";
  };

  window.addEventListener("astro:page-load", () => {
    syncScrollTrigger();
    refreshAll();
    unlockIfNavClosed();
  }, { passive: true });
  window.addEventListener("astro:after-swap", () => {
    syncScrollTrigger();
    refreshAll();
    unlockIfNavClosed();
  }, { passive: true });
  window.addEventListener("astro:hydrate", refreshAll, { passive: true });
  window.addEventListener("astro:visible", refreshAll, { passive: true });
  window.addEventListener("load", refreshAll, { passive: true });
  window.addEventListener("content:loaded", refreshAll, { passive: true });
  window.addEventListener("preloaderComplete", () => {
    refreshAll();
    unlockIfNavClosed();
  }, { passive: true });

  if (lenis && "ResizeObserver" in window) {
    resizeObserver = new ResizeObserver(() => {
      refreshAll();
    });
    resizeObserver.observe(document.body);
  }

  window.__lenis = lenis;
</script>
